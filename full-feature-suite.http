  client.assert(Array.isArray(response.body.data.safeStudents), "Expected safeStudents");
  client.assert(Array.isArray(response.body.data.warningStudents), "Expected warningStudents");
  client.assert(Array.isArray(response.body.data.criticalStudents), "Expected criticalStudents");
});
