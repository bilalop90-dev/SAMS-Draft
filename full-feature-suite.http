### 25. Create a student login for seeded roll 109
POST {{baseUrl}}/auth/create-student?teacherId={{khanTeacherId}}&course=BCA&semester=1
Content-Type: application/json

{
  "username": "{{suiteStudentUsername}}",
  "password": "{{suiteStudentPassword}}",
  "name": "Noor Fatima",
  "studentId": "{{noorRoll}}"
}

> {%
client.test("Teacher can create a student login", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.role === "STUDENT", "Expected STUDENT role");
  client.assert(response.body.data.studentId === client.global.get("noorRoll"), "Expected roll 109");
});
%}

