### 29. Add a temporary student in BCA semester 1
POST {{baseUrl}}/students?teacherId={{khanTeacherId}}
Content-Type: application/json

{
  "name": "{{suiteStudentName}}",
  "rollNumber": "{{suiteStudentRoll}}",
  "course": "BCA",
  "semester": 1
}

> {%
client.test("Student creation works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.rollNumber === client.global.get("suiteStudentRoll"), "Expected temp roll number");
});
client.global.set("suiteStudentDocId", response.body.data.id);
%}

### 30. Update the temporary student
PUT {{baseUrl}}/students/{{suiteStudentDocId}}?teacherId={{khanTeacherId}}
Content-Type: application/json

{
  "name": "{{suiteStudentUpdatedName}}",
  "rollNumber": "{{suiteStudentRoll}}",
  "course": "BCA",
  "semester": 1
}

> {%
client.test("Student update works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.name === client.global.get("suiteStudentUpdatedName"), "Expected updated name");
});
%}

### 31. Verify the temporary student appears in Khan's class list
GET {{baseUrl}}/students?teacherId={{khanTeacherId}}&course=BCA&semester=1

> {%
client.test("Temporary student appears in class list", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.some(function (student) {
    return student.rollNumber === client.global.get("suiteStudentRoll");
  }), "Expected temp student in response");
});
%}

