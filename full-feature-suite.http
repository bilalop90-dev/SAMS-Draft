### 18. Download CSV report for seeded student 101
GET {{baseUrl}}/report/csv/{{seedStudentRoll}}?teacherId={{khanTeacherId}}&course=BCA&semester=1
Accept: text/csv

> {%
client.test("CSV report endpoint responds with CSV headers", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  const contentType = response.headers.valueOf("Content-Type") || "";
  const disposition = response.headers.valueOf("Content-Disposition") || "";
  client.assert(contentType.includes("text/csv"), "Expected text/csv");
  client.assert(disposition.includes(".csv"), "Expected CSV filename");
});
%}

### 19. Download PDF report for seeded student 101
GET {{baseUrl}}/report/pdf/{{seedStudentRoll}}?teacherId={{khanTeacherId}}&course=BCA&semester=1
Accept: application/pdf

> {%
client.test("PDF report endpoint responds with PDF headers", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  const contentType = response.headers.valueOf("Content-Type") || "";
  const disposition = response.headers.valueOf("Content-Disposition") || "";
  client.assert(contentType.includes("application/pdf"), "Expected application/pdf");
  client.assert(disposition.includes(".pdf"), "Expected PDF filename");
});
%}

### 20. Register a new teacher for mapping tests
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{suiteTeacherUsername}}",
  "password": "{{suiteTeacherPassword}}",
  "name": "{{suiteTeacherName}}"
}

> {%
client.test("Teacher registration works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.role === "TEACHER", "Expected TEACHER role");
  client.assert(!!response.body.data.teacherId, "Expected teacherId");
});
client.global.set("suiteTeacherId", response.body.data.teacherId);
%}

### 21. Login as the newly registered teacher
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{suiteTeacherUsername}}",
  "password": "{{suiteTeacherPassword}}"
}

> {%
client.test("New teacher login works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.role === "TEACHER", "Expected TEACHER role");
});
%}

### 22. Assign BCA semester 1 to the new teacher
POST {{baseUrl}}/teachers/{{suiteTeacherId}}/classes
Content-Type: application/json

{
  "course": "BCA",
  "semester": 1
}

> {%
client.test("Teacher class assignment works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.data.course === "BCA", "Expected BCA course");
  client.assert(response.body.data.semester === 1, "Expected semester 1");
});
%}

