@baseUrl = http://localhost:8080

# Full API verification suite for the current demo seed.
# If seeded logins such as khan / ali_student do not exist, enable
# app.demo-data.reset=true once, restart the app, then switch it back to false.
# Run the requests in order from top to bottom.

### 1. Login as seeded teacher and initialize dynamic suite variables
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "khan",
  "password": "pass123"
}

> {%
client.test("Seeded teacher login works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.success === true, "Expected success=true");
  client.assert(response.body.data.role === "TEACHER", "Expected TEACHER role");
  client.assert(!!response.body.data.teacherId, "Expected teacherId");
});

client.global.set("khanTeacherId", response.body.data.teacherId);
client.global.set("seedStudentRoll", "101");
client.global.set("noorRoll", "109");

const stamp = Date.now().toString();
client.global.set("suiteTeacherUsername", "suite_teacher_" + stamp);
client.global.set("suiteTeacherPassword", "SuitePass123");
client.global.set("suiteTeacherName", "Suite Teacher " + stamp);
client.global.set("suiteStudentRoll", "S" + stamp);
client.global.set("suiteStudentName", "Suite Student " + stamp);
client.global.set("suiteStudentUpdatedName", "Suite Student Updated " + stamp);
client.global.set("suiteStudentUsername", "suite_student_" + stamp);
client.global.set("suiteStudentPassword", "StudentPass123");
client.global.set("suiteStudentNewPassword", "StudentPass456");
client.global.set("suiteAttendanceDate", new Date().toISOString().slice(0, 10));
%}

### 2. Login as seeded student
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "ali_student",
  "password": "pass123"
}

> {%
client.test("Seeded student login works", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.success === true, "Expected success=true");
  client.assert(response.body.data.role === "STUDENT", "Expected STUDENT role");
  client.assert(response.body.data.studentId === "101", "Expected roll 101");
});
%}

### 3. Get all students without teacher filter
GET {{baseUrl}}/students

> {%
client.test("Global student list is returned", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(Array.isArray(response.body.data), "Expected array payload");
  client.assert(response.body.data.length >= 10, "Expected seeded students");
});
%}

### 4. Get teacher class mappings for Khan
GET {{baseUrl}}/teachers/{{khanTeacherId}}/classes

> {%
client.test("Teacher class mappings are returned", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(Array.isArray(response.body.data.classes), "Expected classes array");
  client.assert(response.body.data.classes.length >= 2, "Expected seeded mappings");
});
%}

### 5. Get teacher-scoped student groups for Khan
GET {{baseUrl}}/teachers/{{khanTeacherId}}/my-students

> {%
client.test("Teacher-scoped students are grouped by class", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(Array.isArray(response.body.data.classGroups), "Expected classGroups array");
  client.assert(response.body.data.classGroups.length >= 1, "Expected at least one class group");
});
%}

### 6. Get BCA semester 1 students for Khan
GET {{baseUrl}}/students?teacherId={{khanTeacherId}}&course=BCA&semester=1

> {%
client.test("Teacher-scoped class student list is returned", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(Array.isArray(response.body.data), "Expected array payload");
  client.assert(response.body.data.some(function (student) {
    return student.rollNumber === "101";
  }), "Expected seeded roll 101");
});
%}

### 7. Get all attendance for Khan's BCA semester 1 class
GET {{baseUrl}}/attendance?teacherId={{khanTeacherId}}&course=BCA&semester=1

> {%
client.test("Class attendance list is returned", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(Array.isArray(response.body.data), "Expected array payload");
  client.assert(response.body.data.length >= 14, "Expected seeded attendance rows");
});
%}

